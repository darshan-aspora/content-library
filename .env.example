# Copy to .env and fill in real values: cp .env.example .env

# Prisma datasource. SQLite locally; switch to a postgres:// URL for production.
DATABASE_URL="file:./dev.db"

# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET="change-me-to-a-long-random-string"

# Port the Express API listens on (Vite dev server proxies /api and /uploads here).
API_PORT=3001
